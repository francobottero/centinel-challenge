{
  "name": "centinel-challenge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n app,worker,ws -c blue,green,magenta \"npm:dev:app\" \"npm:worker:expense-reports\" \"npm:ws:expense-reports\"",
    "dev:app": "next dev",
    "build": "next build",
    "start": "next start",
    "worker:expense-reports": "node --env-file=.env --import tsx workers/expense-report-worker.ts",
    "ws:expense-reports": "node --env-file=.env --import tsx servers/expense-report-websocket.ts",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:init": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force && rm -rf storage/receipts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@google/genai": "^1.46.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/ws": "^8.18.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "ioredis": "^5.10.1",
    "next": "16.2.0",
    "next-auth": "^4.24.13",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
